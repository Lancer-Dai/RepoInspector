# GitHub Personal Access Token（可选，配置后可提升 API 限流到 5000/h）
# 在 https://github.com/settings/tokens 生成
GITHUB_TOKEN=
REQUEST_TIMEOUT=10
CACHE_TTL_SECONDS=300

# 大模型配置（OpenAI 兼容协议，如 SiliconFlow / 智谱 / DeepSeek 等）
LLM_API_KEY=
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3.5-4B
LLM_TIMEOUT=30
LLM_CACHE_TTL_SECONDS=3600
