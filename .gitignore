# ============================================================
#  Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
pip-wheel-metadata/

# ============================================================
#  虚拟环境
# ============================================================
venv/
.venv/
env/

# ============================================================
#  敏感配置（永远不提交）
#  把 .env.example 提交作为模板，真实 .env 留在本地
# ============================================================
.env
.env.*
backend/.env
backend/.env.*
!.env.example

# ============================================================
#  PyInstaller 中间产物与原始 exe
#  release/*.zip 才是要分发的产物，dist/ 可由 build.py 重新生成
# ============================================================
build/
dist/
*.spec

# ============================================================
#  测试/调试临时文件
# ============================================================
*.log
health*.json
analyze.json
out.log
req.json
test.log
test-err.log
task.log
proc.log
port.log
kill.log
zip.log
build-*.log

# ============================================================
#  IDE / 编辑器
# ============================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
#  Node / 前端（如果用 npm）
# ============================================================
node_modules/
.npm/
.parcel-cache/
